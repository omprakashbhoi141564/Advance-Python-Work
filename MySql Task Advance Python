--14. Show employees whose name starts with 'a'.
SELECT * FROM giet WHERE name like 'a%';

--15. Display employees whose name ends with 'h'.
SELECT * FROM giet WHERE name like '%h';

--16. Show employees whose address contains 'pur'.
