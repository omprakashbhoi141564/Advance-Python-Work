--5. Display all employees whose name is 'aman'.
SELECT * FROM giet WHERE name='aman';

--6. Show employees who live in 'delhi'.
SELECT * FROM giet WHERE address= 'delhi';

--7. Display all employees whose gender is 'M'.
SELECT * FROM giet WHERE gender= 'M';

--8. Show employees whose designation is 'doctor'.
SELECT * FROM giet WHERE desig='doctor';

--9. Display employees having salary 15000.
SELECT * FROM giet WHERE salary=15000;

--10. Show employees with salary greater than 20000.
SELECT * FROM giet WHERE salary>15000;

--11. Display employees with salary less than 30000.
SELECT * FROM giet WHERE salary<30000;

--12. Show employees who are male AND have salary > 20000.
SELECT * FROM giet WHERE salary>20000 and gender='M';

--13. Display employees who are female OR live in 'raipur'.
